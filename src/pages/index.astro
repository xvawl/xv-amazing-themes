---
import BaseLayout from "../layouts/BaseLayout.astro";
import { getAllThemes } from "../lib/theme-model";

const themes = getAllThemes();
const baseUrl = import.meta.env.BASE_URL;
const toBase = (path: string) => `${baseUrl}${path.replace(/^\//, "")}`;
---
<BaseLayout title="Amazing Themes" description="A theme lab for previewing and iterating on themes.">
  <div class="grid">
    <div class="card" style="grid-column: span 12;">
      <div class="hd">
        <div>
          <div class="kicker">Source of truth</div>
          <h1 class="title">Themes in this repo</h1>
        </div>
        <div class="pill mono">Loaded from `themes/**/&#123;light,dark&#125;.yml`</div>
      </div>
      <div class="bd" style="padding-top: 10px;">
        {themes.length === 0 ? (
          <p class="tagline">No themes found in `themes/`.</p>
        ) : (
          <div class="grid" style="gap: 12px;">
            {themes.map((t) => {
              const variants = Object.keys(t.variants ?? {});
              return (
                <a class="card" style="grid-column: span 6;" href={toBase(`/themes/${t.name}/${variants.includes("light") ? "light" : variants[0]}/`)}>
                  <div class="bd">
                    <div class="kicker">Theme</div>
                    <div class="title">{t.name}</div>
                    <div style="margin-top: 10px; display: flex; gap: 8px; flex-wrap: wrap;">
                      {variants.map((v) => (
                        <span class="pill">{v}</span>
                      ))}
                      <span class="pill mono">playground + downloads</span>
                    </div>
                  </div>
                </a>
              );
            })}
          </div>
        )}
      </div>
    </div>
  </div>
</BaseLayout>
