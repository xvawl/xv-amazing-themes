---
import "../styles/global.css";
import { ViewTransitions } from "astro:transitions";
const { title, description, wideHeader = false } = Astro.props;
const homeHref = import.meta.env.BASE_URL;
const assetHref = (path: string) => `${homeHref}${path.replace(/^\//, "")}`;
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description ?? "A theme lab for previewing palettes and semantic roles."} />
    <link rel="icon" href={assetHref("/favicon.ico")} sizes="any" />
    <link rel="icon" type="image/png" href={assetHref("/icon.png")} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,400;0,500;0,700;1,400&family=Instrument+Sans:ital,wght@0,400;0,500;0,600;0,700;1,400&display=swap"
      rel="stylesheet"
    />
    <ViewTransitions />
    <title>{title ?? "Amazing Themes"}</title>
  </head>
  <body>
    <header class="topbar">
      <div class={wideHeader ? "topbar-inner" : "topbar-inner topbar-inner--constrained"}>
        <div class="brand" transition:name="topbar-brand"><a href={homeHref}>amazing-themes</a></div>
        <div class="topbar-sep" transition:name="topbar-sep"></div>
        <div class="topbar-desc" transition:name="topbar-desc">preview palettes · export to tools</div>
        <div class="topbar-right" transition:name="topbar-right">
          <span class="badge">theme-lab</span>
        </div>
      </div>
    </header>
    <slot />
  </body>
</html>
