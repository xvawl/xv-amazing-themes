---
type ThemeSetup = Record<string, string>;
type SnippetMap  = Record<string, string>;

interface Props {
  themeSetup:       ThemeSetup;
  snippets:         SnippetMap;
  initialLanguage?: string;
  label?:           string;
}

const {
  themeSetup,
  snippets,
  initialLanguage = "javascript",
  label = "editor",
} = Astro.props;

const languageEntries = Object.entries(snippets);
const editorBg = themeSetup["editor.background"] ?? "#ffffff";
const editorFg = themeSetup["editor.foreground"] ?? "#111111";
---

<div
  class="sample"
  data-code-editor
  style={`background: ${editorBg}; color: ${editorFg};`}
>
  <script
    type="application/json"
    data-code-editor-payload
    set:html={JSON.stringify({ snippets, semantic: themeSetup, initialLanguage })}
  />

  <!-- Window chrome -->
  <div class="toolbar">
    <span class="bubble"></span>
    <span class="bubble"></span>
    <span class="bubble"></span>
  </div>

  <!-- Language bar -->
  <div class="ce-lang-bar">
    {languageEntries.map(([language]) => (
      <button class="lang-btn" data-lang-btn={language}>
        {language[0]?.toUpperCase()}{language.slice(1)}
      </button>
    ))}
    <button class="ce-reset-btn" data-reset-btn title="Reset to default snippets">↺ reset</button>
    <span class="ce-label">{label}</span>
  </div>

  <!-- CodeMirror mount -->
  <div data-editor-mount></div>
</div>

<script>
  // ─── Module-level state ─────────────────────────────────────────────────────
  // Persists across client-side navigations (ES module is cached).
  // Cleared on full page refresh — that's the user's "undo".

  let runtime: Promise<any> | null = null;

  // code content per language, shared across all theme pages
  const codeByLang = new Map<string, string>();
  // last active language, restored on next navigation
  let lastLanguage = "";

  // ─── CSS var mapping ────────────────────────────────────────────────────────

  const roleToCss: Record<string, string> = {
    "editor.background":  "--preview-editor-bg",
    "editor.foreground":  "--preview-editor-fg",
    "ui.panelBackground": "--preview-panel-bg",
    "ui.subtleText":      "--preview-subtle",
    "syntax.keyword":     "--preview-keyword",
    "syntax.string":      "--preview-string",
    "syntax.function":    "--preview-function",
    "syntax.number":      "--preview-number",
    "syntax.variable":    "--preview-variable",
    "syntax.error":       "--preview-error",
  };

  // ─── Load CodeMirror (once, then cached) ────────────────────────────────────

  async function loadRuntime() {
    if (runtime) return runtime;
    runtime = Promise.all([
      import("codemirror"),
      import("@codemirror/state"),
      import("@codemirror/view"),
      import("@codemirror/language"),
      import("@codemirror/lang-javascript"),
      import("@codemirror/lang-python"),
      import("@codemirror/lang-rust"),
      import("@codemirror/lang-yaml"),
      import("@lezer/highlight"),
    ]).then(([cm, stateM, viewM, langM, jsM, pyM, rsM, yamlM, hlM]) => {
      const { basicSetup }                         = cm;
      const { EditorState, Compartment }           = stateM;
      const { EditorView }                         = viewM;
      const { syntaxHighlighting, HighlightStyle } = langM;
      const { javascript }                         = jsM;
      const { python }                             = pyM;
      const { rust }                               = rsM;
      const { yaml }                               = yamlM;
      const { tags }                               = hlM;

      const langs: Record<string, any> = {
        javascript: javascript(),
        python:     python(),
        rust:       rust(),
        yaml:       yaml(),
      };

      const editorTheme = EditorView.theme({
        "&": {
          height:          "100%",
          backgroundColor: "var(--preview-editor-bg)",
          color:           "var(--preview-editor-fg)",
          fontFamily:      "var(--font-mono, ui-monospace, monospace)",
          fontSize:        "14px",
        },
        ".cm-editor":  { height: "100%", backgroundColor: "var(--preview-editor-bg)" },
        ".cm-scroller": { fontFamily: "inherit", lineHeight: "1.6", overflow: "auto" },
        ".cm-gutters": {
          backgroundColor: "var(--preview-panel-bg, var(--preview-editor-bg))",
          color:           "var(--preview-subtle, var(--preview-editor-fg))",
          border:          "none",
          opacity:         "0.6",
        },
        ".cm-content":          { caretColor: "var(--preview-editor-fg)", padding: "14px 16px" },
        ".cm-activeLineGutter": { backgroundColor: "transparent" },
        ".cm-activeLine":       { backgroundColor: "transparent" },
        ".cm-cursor, .cm-dropCursor": { borderLeftColor: "var(--preview-editor-fg)" },
        ".cm-selectionBackground, ::selection": {
          backgroundColor: "var(--preview-panel-bg, rgba(127,127,127,0.2))",
        },
        "&.cm-focused": { outline: "none" },
      });

      const highlightTheme = syntaxHighlighting(
        HighlightStyle.define([
          { tag: [tags.keyword, tags.modifier, tags.operatorKeyword],               color: "var(--preview-keyword)"  },
          { tag: [tags.string, tags.special(tags.string)],                          color: "var(--preview-string)"   },
          { tag: [tags.function(tags.variableName), tags.function(tags.propertyName)], color: "var(--preview-function)" },
          { tag: [tags.number, tags.integer, tags.float, tags.bool],                color: "var(--preview-number)"   },
          { tag: [tags.variableName, tags.propertyName, tags.attributeName],        color: "var(--preview-variable)" },
          { tag: [tags.invalid, tags.deleted],                                      color: "var(--preview-error)"    },
        ])
      );

      return { EditorState, EditorView, Compartment, basicSetup, editorTheme, highlightTheme, langs };
    });
    return runtime;
  }

  // ─── Init one editor instance ───────────────────────────────────────────────

  async function initCodeEditor(editor: Element) {
    // Clear stale ready flag (element may be new DOM node after navigation)
    const el = editor as HTMLElement;

    // Already initialized in this DOM instance
    if (el.dataset.codeEditorReady === "true") return;
    el.dataset.codeEditorReady = "true";

    const payloadEl = editor.querySelector("[data-code-editor-payload]");
    const payload   = payloadEl ? JSON.parse(payloadEl.textContent || "{}") : {};
    const snippets: Record<string, string> = payload.snippets || {};
    const semantic: Record<string, string> = payload.semantic || {};
    const defaultLang = payload.initialLanguage || "javascript";
    const mount       = editor.querySelector("[data-editor-mount]") as HTMLElement | null;
    const langBtns    = editor.querySelectorAll<HTMLElement>("[data-lang-btn]");
    const resetBtn    = editor.querySelector<HTMLElement>("[data-reset-btn]");
    if (!mount) return;

    // Restore last used language, fall back to default
    let currentLang = (lastLanguage && snippets[lastLanguage]) ? lastLanguage : defaultLang;

    const { EditorState, EditorView, Compartment, basicSetup, editorTheme, highlightTheme, langs }
      = await loadRuntime();

    const langCompartment = new Compartment();
    const initialDoc = codeByLang.get(currentLang) ?? snippets[currentLang] ?? "";

    const view = new EditorView({
      state: EditorState.create({
        doc: initialDoc,
        extensions: [
          basicSetup,
          editorTheme,
          highlightTheme,
          EditorView.lineWrapping,
          langCompartment.of(langs[currentLang] || []),
          // Auto-save content to module-level Map on every keystroke
          EditorView.updateListener.of((update) => {
            if (update.docChanged) {
              codeByLang.set(currentLang, view.state.doc.toString());
            }
          }),
        ],
      }),
      parent: mount,
    });

    function applyColors() {
      for (const [role, value] of Object.entries(semantic)) {
        const cssVar = roleToCss[role];
        if (cssVar) el.style.setProperty(cssVar, value);
      }
      if (semantic["editor.background"]) el.style.background = semantic["editor.background"];
      if (semantic["editor.foreground"]) el.style.color      = semantic["editor.foreground"];
    }

    function setLanguage(lang: string) {
      if (!snippets[lang]) return;
      // Snapshot the current content before leaving this language
      codeByLang.set(currentLang, view.state.doc.toString());
      const content = codeByLang.get(lang) ?? snippets[lang];
      // ⚠️ Must update currentLang BEFORE view.dispatch — the updateListener
      // fires synchronously inside dispatch, and must see the NEW lang so it
      // saves incoming content to the correct key instead of overwriting the old one.
      currentLang  = lang;
      lastLanguage = lang;
      view.dispatch({
        changes: { from: 0, to: view.state.doc.length, insert: content },
        effects: langCompartment.reconfigure(langs[lang] || []),
      });
      for (const btn of langBtns) {
        btn.classList.toggle("is-active", btn.dataset.langBtn === lang);
      }
    }

    for (const btn of langBtns) {
      btn.addEventListener("click", () => setLanguage(btn.dataset.langBtn || defaultLang));
    }

    // Reset: clear all saved content and restore default snippet
    if (resetBtn) {
      resetBtn.addEventListener("click", () => {
        codeByLang.clear();
        view.dispatch({
          changes: { from: 0, to: view.state.doc.length, insert: snippets[currentLang] ?? "" },
        });
      });
    }

    setLanguage(currentLang);
    applyColors();
  }

  // ─── Re-run after every client-side navigation ──────────────────────────────
  // astro:page-load fires on initial load AND after every ViewTransition.
  // ES module is cached, so this listener is registered exactly once.

  document.addEventListener("astro:page-load", () => {
    document.querySelectorAll("[data-code-editor]").forEach(initCodeEditor);
  });
</script>
